# ==============================================================================
# CONFIGURATION APLIKASI
# ==============================================================================
APP_NAME="Mini MVC Application"
APP_ENV=local                       # local, staging, atau production
APP_KEY=base64:random_string_key_anda_disini
APP_DEBUG=true                       # true untuk development, false untuk production
APP_URL=http://localhost/haji_ayat_kurma
APP_TIMEZONE=UTC

# ==============================================================================
# CONFIGURATION DATABASE (Koneksi SQL)
# ==============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=haji_ayat_kurma
DB_USERNAME=root
DB_PASSWORD=

# ==============================================================================
# CONFIGURATION MAIL / SMTP (Opsional - Jika ada fitur kirim email)
# ==============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="admin@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================================================
# CONFIGURATION SESSION & CACHE (Jika diperlukan)
# ==============================================================================
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120