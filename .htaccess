<IfModule mod_rewrite.c>
    RewriteEngine On

    # Izinkan akses langsung ke folder public/ (CSS, JS, gambar, upload)
    RewriteRule ^public/ - [L,NC]

    # Arahkan aset statis ke folder public/ tanpa melalui PHP
    RewriteRule ^(css|js|images|uploads)/(.*)$ public/$1/$2 [L,NC]

    # Semua request lain (route PHP) → public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php?url=$1 [QSA,L]
</IfModule>
